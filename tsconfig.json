{
  "compilerOptions": {
    "target": "ES2020" /* Modern JavaScript version */,
    "module": "commonjs" /* The module system Node.js uses */,
    "rootDir": "./src" /* Where to find our TypeScript files */,
    "outDir": "./dist" /* Where to put the compiled JavaScript files */,
    "esModuleInterop": true /* Better compatibility with CommonJS modules */,
    "forceConsistentCasingInFileNames": true,
    "strict": true /* Enable all strict type-checking options */,
    "skipLibCheck": true
  },
  "include": ["src/**/*"] /* Only compile files in the 'src' directory */
}
